{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "script/**/*.ts",
    "client/**/*.ts",
    "client/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "drizzle.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
